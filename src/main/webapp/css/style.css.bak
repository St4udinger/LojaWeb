:root {
  --bg-main: #f6f8fb;
  --bg-card: #ffffff;
  --bg-card-shadow: #e5eaf3;
  --accent: #4254f3;
  --accent-gradient: linear-gradient(100deg, #4254f3 85%, #33c68a 100%);
  --accent-secondary: #33c68a;
  --gray1: #23272f;
  --gray2: #444956;
  --gray3: #5f6470;
  --gray-bg: #eef1f7;
  --danger: #ff4c4c;
  --success: #33c68a;
  --radius: 18px;
  --radius-card: 22px;
  --duration: 0.22s;
}

body {
  margin: 0;
  min-height: 100vh;
  background: var(--bg-main);
  color: var(--gray1);
  font-family: 'Segoe UI', Arial, Helvetica, sans-serif;
}

.container {
  max-width: 1250px; margin: 0 auto; width: 93vw; display: flex; justify-content: space-between; align-items: center;
}

.modern-navbar {
  position: fixed; top: 0; left: 0; width: 100vw; z-index: 9999;
  padding: 0; background: rgba(255,255,255,.91); transition: background var(--duration), box-shadow var(--duration);
  height: 65px; display: flex; align-items: center; box-shadow: 0 2px 16px #23213311;
}
.modern-navbar .brand {
  font-weight: 900; font-size: 1.52rem;
  letter-spacing: 2px; color: var(--accent);
  display: flex; align-items: center; gap: 9px;
}
.modern-navbar ul {
  display: flex; align-items: center; gap: 12px; list-style: none; margin: 0;
}
.modern-navbar ul li a {
  color: var(--gray3); text-decoration: none;
  font-weight: 600; font-size: 1.01rem; padding: 9px 18px; border-radius: 17px;
  transition: background .2s,color .18s;
  display: block;
}
.modern-navbar ul li a:hover,
.modern-navbar ul li a:focus {
  background: var(--accent-gradient);
  color: #fff;
}
.modern-navbar .ghost {
  background: none; border: 2px solid var(--accent);
  color: var(--accent); font-weight: 700;
  padding: 8px 24px; font-size: 1rem; border-radius: 19px;
  transition: background .2s, color .16s, border .14s;
  cursor: pointer; outline: 0;
  margin-left: 20px;
}
.modern-navbar .ghost:hover,
.modern-navbar .ghost:focus {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}
.menu-mobile { display: none; flex-direction: column; gap: 4px; cursor: pointer; }
.menu-mobile span { width: 28px; height: 3px; border-radius: 7px; background: var(--accent);}
@media (max-width: 900px) {
  .container { flex-direction: column; }
  .modern-navbar ul { display: none; }
  .modern-navbar ul.active { display: flex; flex-direction: column;
    background: var(--bg-main); position: absolute; top: 59px; left: 0; right: 0; padding: 19px 0;
    border-radius: 0 0 17px 17px; box-shadow: 0 12px 24px #3344;
  }
  .menu-mobile { display: flex;}
}

/* HERO — Centralizado, clean */
.modern-hero {
  min-height: 80vh;
  display:flex; flex-direction:column; align-items:center; justify-content: center;
  box-sizing:border-box; width:100vw; text-align:center;
  background: linear-gradient(110deg, #e5eaf7 0, #e5eaf5 40%, #f1f4fa 100%);
  position: relative;
  padding-top: 65px;
}
.hero-content {
  max-width: 600px; margin:0 auto;
  display:flex; flex-direction:column; align-items:center;
  justify-content:center;
  gap:28px;
  padding-top: 34px; padding-bottom: 68px;
  animation: fadein 0.8s;
}
@keyframes fadein {
  from{opacity:0; transform:translateY(19px);}
  to{opacity:1; transform:translateY(0);}
}
.hero-content h1 {
  margin-bottom:0;
  color: var(--gray1);
  font-size: 2.6rem;
  font-weight: 800;
  line-height: 1.19;
  letter-spacing:1.2px;
}
.hero-content h1 span {
  color: var(--accent);;
}
.hero-content p {
  color: var(--gray2);
  font-size: 1.18rem;
  margin-bottom: 0;
}
.search-box-glass {
  margin: 0 auto; max-width:350px; position:relative;
  background: #eef1f7;
  border-radius:30px; box-shadow: 0 2px 13px #4254f35d;
  transition: box-shadow .21s;
  padding:4px 1.2em;
  display: flex; align-items:center;
}
.search-box-glass input {
  width: 100%; background: transparent;
  border: none; outline: none;
  padding: 14px 2em 14px 0; color: var(--gray2);
  font-size: 1rem; border-radius:33px;
}
.search-box-glass i {
  position: absolute; right: 17px; top: 48%; transform: translateY(-50%);
  opacity: .67; color: var(--accent);
  font-size:1.1rem;
}

.cta {
  margin-top:8px; background: var(--accent-gradient);
  color: #fff; font-weight: bold; border: none;
  font-size: 1.09rem; padding: 14px 30px; border-radius: 17px;
  cursor: pointer; box-shadow: 0 4px 24px #4254f340;
  transition: filter .19s, transform .13s;
  font-family: inherit;
}
.cta:hover, .cta:focus {
  filter: brightness(1.12);
  transform: translateY(-2px) scale(1.05);
}

/* ITENS */
.modern-itens {
  max-width: 1250px; margin: 0 auto; padding: 68px 3vw 0 3vw;
}
.section-title {
  display:flex; align-items: center; justify-content: space-between;
  flex-wrap:nowrap; gap:19px; margin-bottom:39px;
}
.section-title h2 {
  font-size:1.5rem; color:var(--accent); font-weight:700; letter-spacing:.1em; display:flex;align-items:center;gap:7px;
}
.filters { display:flex; gap:14px;}
.filters button {
  border:none; background: #f2f4fb; font-weight:bold; color: var(--gray2);;
  border-radius:14px; padding:8px 22px; cursor:pointer;
  box-shadow:0 2px 7px #4254f311; transition: box-shadow .18s,background .18s;
}
.filters button.active,
.filters button:hover { background: var(--accent); color: #fff; }

.modern-cards {
  display:grid; grid-template-columns: repeat(auto-fit,minmax(255px,1fr));
  gap:32px; justify-items:center;
}
.modern-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  box-shadow: 0 8px 32px 0 var(--bg-card-shadow);
  transition: box-shadow .18s, transform .12s;
  min-height: 198px; min-width: 220px;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  padding: 35px 22px 27px 22px;
  position:relative;
  text-align:center;
}
.modern-card:hover { box-shadow: 0 18px 32px 2px #4254f36f; transform: scale(1.033);}
.modern-card .icon { font-size:2.3rem; margin-bottom:17px; color:var(--gray1);}
.modern-card h3 {
  margin:0; font-size: 1.14rem; color: var(--gray1); font-weight:700;
}
.modern-card .details { display:flex; flex-direction:column; gap:8px; align-items:center;}
.badge {
  font-size:.93rem; font-weight:600; border-radius: 16px; padding: 7px 16px;
  letter-spacing:.01em; margin-top:5px; margin-bottom:0;
  display:inline-block;
}
.perdido { background:#ffe2e2; color: var(--danger);}
.encontrado { background:#e7fcea; color: var(--success);}
.local { color: var(--accent); font-size:.99em; margin:5px 0 0 0; }
small{color: #8d97aa; font-size:.93rem;}

.sobre { background: var(--gray-bg); padding:63px 0; text-align:center;}
.sobre-content { max-width:570px; margin:auto;}
.sobre h2 { color: var(--accent); margin-bottom:12px;}
.sobre p { color: var(--gray2); font-size:1.13em; margin-top:14px;}
.sobre i { color: var(--accent-secondary); font-size: 1.15em;}

.modern-footer {
  background: var(--gray1); color: #fff; display: flex;
  gap:32px; padding: 44px 8vw 16px 8vw; flex-wrap:wrap;
  align-items: flex-start; justify-content: space-between;
  margin-top:82px;
}
.footer-col {
  flex: 1 1 340px;
  max-width: 430px;
  min-width: 290px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
}
.footer-col h3 { color: var(--accent-secondary); }
.footer-copy { width:100%; text-align:center; margin-top:32px;color:#b5bdd2;font-size:.98em;}
.contactform input, .contactform textarea {
  display: block;
  width: 100%;
  margin-bottom: 15px;
  background: #eef1f7;
  border: 2px solid #e0e7ff;
  border-radius: 13px;
  padding: 13px 16px;
  font-size: 1rem;
  font-family: inherit;
  outline: none;
  transition: border .18s;
}

.contactform {
  width: 100%;
  max-width: 430px;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 15px;
}
.contactform input:focus, .contactform textarea:focus {border-color: var(--accent);}
.contactform textarea { min-height: 70px;}
.contactform button {width:130px; float:right; margin-top:4px;}

@media (max-width: 1000px) {
  .modern-footer {
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }
  .footer-col {
    width: 100%;
    max-width: 500px;
    align-items: flex-start;
    margin-bottom: 32px;
  }
  .contactform {
    margin-left: 0;
    margin-right: 0;
    align-items: stretch;
  }
}

@media (max-width: 700px) {
  .modern-cards {grid-template-columns:1fr;}
  .hero-content {padding-top:20px;padding-bottom:35px;}
}

.search-results {
  position: absolute;
  top: 110%;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 8px 22px #0000001f;
  overflow: hidden;
  z-index: 20;
  display: none;
}

.search-results div {
  padding: 12px 16px;
  cursor: pointer;
  font-size: 0.98rem;
  color: #333;
  transition: background 0.2s;
}
.search-results div:hover {
  background: #f1f4ff;
}

/* MODAL FINAL (ÚNICO) */
.modal2{
  position:fixed;
  inset:0;
  display:none;
  align-items:center;
  justify-content:center;
  background:rgba(0,0,0,.55);
  z-index:999999;
}
.modal2-content{
  background:#fff;
  width:min(520px,94vw);
  border-radius:18px;
  padding:26px 24px 22px;
  box-shadow:0 20px 60px rgba(0,0,0,.25);
  position:relative;
}
.close2{
  position:absolute;
  top:12px;
  right:14px;
  font-size:22px;
  cursor:pointer;
  color:#7b7b7b;
}

.modal2-content form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-areas:
    "title title"
    "type  local"
    "desc  desc"
    "btn   btn";
  gap: 12px;
}

.modal2-content input,
.modal2-content select,
.modal2-content textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 10px 12px;
  border: 1px solid #d9d9e3;
  border-radius: 10px;
  font-size: .95rem;
  background: #fafbff;
}

.modal2-content .f-title { grid-area: title; }
.modal2-content .f-type  { grid-area: type; }
.modal2-content .f-local { grid-area: local; }
.modal2-content .f-desc  { grid-area: desc; min-height: 110px; }

.modal2-content .cta {
  grid-area: btn;
  width: 160px;
  border: none;
  border-radius: 16px;
  padding: 10px 16px;
  background: var(--accent-gradient);
  color: #fff;
  font-weight: 700;
  cursor: pointer;
}

.close2 {
  position: absolute;
  top: 12px;
  right: 14px;
  font-size: 22px;
  cursor: pointer;
  color: #7b7b7b;
}

/* Responsivo */
@media (max-width: 600px) {
  .modal2-content form {
    grid-template-columns: 1fr;
    grid-template-areas:
      "title"
      "type"
      "local"
      "desc"
      "btn";
  }
}

.fab {
  position:fixed;bottom:23px;right:23px;width: 56px;height: 56px;border-radius: 50%;
  background: var(--accent-gradient);
  color:#fff; border:none; box-shadow: 0 7px 20px #4254f343;
  font-size: 2rem; cursor:pointer; z-index:9999; display:flex;align-items:center;justify-content:center;
  transition: filter .15s, transform .13s;
}
.fab:hover, .fab:focus { filter: brightness(1.14); transform: scale(1.09);}
::-webkit-scrollbar { width:8px; background: #eef1f7;}
::-webkit-scrollbar-thumb { background:var(--accent); border-radius:8px;}

/* ===== AUTH PAGES (LOGIN / CADASTRO) ===== */
.auth-page {
  min-height: 100vh;
  padding-top: 90px; /* espaço para navbar fixa */
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-wrapper {
  width: min(520px, 92vw);
  background: #ffffff;
  border-radius: 18px;
  padding: 26px 24px 20px;
  box-shadow: 0 20px 60px rgba(0,0,0,.10);
}

.auth-title {
  margin: 0 0 6px 0;
  font-size: 1.8rem;
  font-weight: 800;
  color: var(--gray1);
  text-align: center;
}

.auth-subtitle {
  margin: 0 0 18px 0;
  text-align: center;
  color: var(--gray2);
}

.auth-alert {
  background: #ffe2e2;
  color: #b20000;
  padding: 10px 12px;
  border-radius: 12px;
  font-weight: 700;
  margin-bottom: 12px;
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.auth-form input {
  width: 100%;
  box-sizing: border-box;
  padding: 12px 14px;
  border: 1px solid #d9d9e3;
  border-radius: 12px;
  font-size: 1rem;
  background: #fafbff;
  outline: none;
}

.auth-form input:focus {
  border-color: var(--accent);
}

.auth-actions {
  margin-top: 6px;
}

.auth-actions .cta {
  width: 100%;
}

.auth-links {
  margin-top: 12px;
  display: flex;
  gap: 8px;
  justify-content: center;
  color: var(--gray2);
}

.auth-links a {
  color: var(--accent);
  font-weight: 800;
  text-decoration: none;
}

.auth-links a:hover {
  text-decoration: underline;
}

/* ===== AUTH MODAL (LOGIN/CADASTRO) ===== */
.auth-modal {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,.55);
  z-index: 1000000;
}

.auth-modal.active { display: flex; }

.auth-modal-content {
  width: min(520px, 94vw);
  background: #fff;
  border-radius: 18px;
  padding: 22px 22px 18px;
  box-shadow: 0 20px 60px rgba(0,0,0,.25);
  position: relative;
}

.auth-close {
  position: absolute;
  top: 12px;
  right: 14px;
  font-size: 22px;
  cursor: pointer;
  color: #7b7b7b;
}

.auth-brand {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-weight: 900;
  font-size: 1.5rem;
  color: var(--accent);
  margin-bottom: 8px;
}

.auth-tabs {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin: 12px 0 16px;
}

.auth-tab {
  border: none;
  background: #f2f4fb;
  color: var(--gray2);
  font-weight: 800;
  border-radius: 14px;
  padding: 10px 18px;
  cursor: pointer;
}

.auth-tab.active {
  background: var(--accent);
  color: #fff;
}

.auth-pane { display: none; }
.auth-pane.active { display: block; }

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.auth-form input {
  width: 100%;
  box-sizing: border-box;
  padding: 12px 14px;
  border: 1px solid #d9d9e3;
  border-radius: 12px;
  font-size: 1rem;
  background: #fafbff;
  outline: none;
}

.auth-form input:focus { border-color: var(--accent); }

.auth-actions { margin-top: 6px; }
.auth-actions .cta { width: 100%; }

.auth-hint {
  text-align: center;
  color: var(--gray2);
  margin-top: 10px;
  font-size: .95rem;
}

.brand{
  display:flex;
  align-items:center;
  gap:10px;
}

.brand-logo{
  width:28px;
  height:28px;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  background: var(--accent);
  box-shadow: 0 6px 16px rgba(66,84,243,.25);
}

.brand-logo i{
  color:#fff;
  font-size:14px;
  transform: rotate(-20deg);

  /* =========================
     Navbar — centralização e cores
     ========================= */

  /* Garante fundo e sombra padrão da navbar */
  .modern-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 9999;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 2px 16px rgba(35,33,51,0.07);
  }

  /* Container alinhado */
  .modern-navbar .container {
    max-width: 1250px;
    margin: 0 auto;
    width: 93vw;
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 0 12px;
  }

  /* Logo (à esquerda) */
  .modern-navbar .brand {
    font-weight: 900;
    font-size: 1.52rem;
    letter-spacing: 1px;
    color: #4254f3;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Menu centralizado */
  .modern-navbar ul {
    flex: 1;
    display: flex;
    justify-content: center;
    gap: 16px;
    margin: 0;
    padding: 0;
    list-style: none;
    align-items: center;
  }

  /* Links do menu */
  .modern-navbar ul li a {
    color: #333;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    padding: 8px 14px;
    border-radius: 12px;
    transition: all 0.18s ease;
    display: inline-block;
  }

  /* Hover com gradiente */
  .modern-navbar ul li a:hover,
  .modern-navbar ul li a:focus {
    background: linear-gradient(100deg, #4254f3 85%, #33c68a 100%);
    color: #fff;
  }

  /* Área do usuário (direita) */
  .user-area {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
  }

  .user-greeting {
    color: #333;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .user-greeting i { color: #4254f3; margin-right: 6px; }

  .btn-logout {
    background: rgba(255,80,80,0.06);
    border: 1px solid rgba(255,80,80,0.18);
    color: #cc3b3b;
    padding: 7px 12px;
    border-radius: 8px;
    font-size: 0.86rem;
    text-decoration: none;
  }

  /* Responsividade: menu mobile colapsado */
  @media (max-width: 900px) {
    .modern-navbar .container { flex-wrap: wrap; }
    .modern-navbar ul {
      display: none;
      position: absolute;
      top: 65px;
      left: 0;
      right: 0;
      flex-direction: column;
      background: #f6f8fb;
      padding: 18px 0;
      gap: 0;
      z-index: 9998;
    }
    .modern-navbar ul.active { display: flex; }
    .modern-navbar ul li a { padding: 10px 20px; display: block; }
    .user-area { order: 3; width: 100%; justify-content: flex-end; padding-top: 8px; }
  }


}